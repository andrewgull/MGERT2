from snakemake.io import expand, directory, touch


rule all:
    input:
        expand("results/final/{sample}.done", sample=config["samples"]),


rule build_database:
    input:
        genome="data/{sample}.fasta.gz",
    output:
        nhr="results/rmod_database/{sample}/{sample}_rmod.nhr",
        nin="results/rmod_database/{sample}/{sample}_rmod.nin",
        njs="results/rmod_database/{sample}/{sample}_rmod.njs",
        nnd="results/rmod_database/{sample}/{sample}_rmod.nnd",
        nni="results/rmod_database/{sample}/{sample}_rmod.nni",
        nog="results/rmod_database/{sample}/{sample}_rmod.nog",
        nsq="results/rmod_database/{sample}/{sample}_rmod.nsq",
        translation="results/rmod_database/{sample}/{sample}_rmod.translation",
    log:
        "logs/{sample}_build_database.log",
    conda:
        "envs/rmod_database.yaml",
    shell:
        """filename={output.nhr}; basename="${{filename%.nhr}}" & BuildDatabase -name ${{basename}} {input.genome} > &> {log}"""


rule final:
    input:
        db_name="results/rmod_database/{sample}/{sample}_rmod.nhr",
    output:
        touch("results/final/{sample}.done"),
    shell:
        "echo 'Done'"
