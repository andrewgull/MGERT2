import os
import csv
from pathlib import Path
from snakemake.io import expand, directory, touch, multiext, temp
from snakemake.utils import validate

# --- Config schema validation (type, range, enum checks) ---
validate(config, "schemas/config.schema.yaml")


def _validate_inputs(cfg):
    """Check that all referenced files and directories exist and are consistent."""
    errors = []

    # Genome files must exist
    for genome_path in cfg.get("genomes", []):
        if not Path(genome_path).exists():
            errors.append(f"Genome file not found: '{genome_path}'")

    # PSSM directory and its contents
    pssm_dir = cfg.get("orf_analysis", {}).get("rpsblast", {}).get("pssm_dir", "data/pfam")
    smp_files = list(Path(pssm_dir).glob("*.smp")) if Path(pssm_dir).is_dir() else []
    if not Path(pssm_dir).is_dir():
        errors.append(f"pssm_dir not found: '{pssm_dir}'")
    elif not smp_files:
        errors.append(f"No *.smp files found in pssm_dir: '{pssm_dir}'")

    # domains.csv: exists, two columns, no duplicates, all .smp files present in pssm_dir
    domains_csv = cfg.get("orf_analysis", {}).get("rpsblast", {}).get("domains_csv", "")
    if domains_csv:
        if not Path(domains_csv).exists():
            errors.append(f"domains_csv not found: '{domains_csv}'")
        else:
            seen_smp = {}
            smp_stems = {f.name for f in smp_files}
            with open(domains_csv, newline="") as fh:
                for i, row in enumerate(csv.reader(fh, delimiter="\t"), start=1):
                    if len(row) != 2:
                        errors.append(f"domains_csv line {i}: expected 2 tab-separated columns, got {len(row)}")
                        continue
                    smp_name, domain_type = row[0].strip(), row[1].strip()
                    if not domain_type:
                        errors.append(f"domains_csv line {i}: domain type is empty for '{smp_name}'")
                    if smp_name in seen_smp:
                        errors.append(
                            f"domains_csv line {i}: duplicate entry '{smp_name}' " f"(first seen on line {seen_smp[smp_name]})"
                        )
                    seen_smp[smp_name] = i
                    if smp_stems and smp_name not in smp_stems:
                        errors.append(f"domains_csv line {i}: '{smp_name}' not found in '{pssm_dir}'")

        # required_domains entries must appear in domains_csv domain types
        required = cfg.get("orf_analysis", {}).get("domain_filter", {}).get("required_domains", [])
        if required and Path(domains_csv).exists():
            known_types = set()
            with open(domains_csv, newline="") as fh:
                for row in csv.reader(fh, delimiter="\t"):
                    if len(row) == 2:
                        known_types.add(row[1].strip())
            unknown = [d for d in required if d not in known_types]
            if unknown:
                errors.append(
                    f"required_domains references unknown domain type(s): {unknown}. "
                    f"Known types from domains_csv: {sorted(known_types)}"
                )

    if errors:
        raise ValueError(
            "Configuration errors found — fix before running the pipeline:\n" + "\n".join(f"  • {e}" for e in errors)
        )


_validate_inputs(config)

# Collect PSSM files that will be compiled into the RPS-BLAST database.
# Set rpsblast.pssm_dir in config to point to a different directory of *.smp files.
_PSSM_DIR = config.get("orf_analysis", {}).get("rpsblast", {}).get("pssm_dir", "data/pfam")
(_SMP_NAMES,) = glob_wildcards(f"{_PSSM_DIR}/{{name}}.smp")

# Derive sample names from genome paths: strip known compression and FASTA
# suffixes so that e.g. "data/E.coli.fasta.gz" → "E.coli".
_COMPRESSION_SUFFIXES = {".gz", ".bz2", ".xz"}
_FASTA_SUFFIXES = {".fasta", ".fa", ".fna", ".ffn", ".fas"}
_SAMPLE_TO_GENOME = {}
for _p in config["genomes"]:
    _stem = Path(_p).name
    if Path(_stem).suffix in _COMPRESSION_SUFFIXES:
        _stem = Path(_stem).stem
    if Path(_stem).suffix in _FASTA_SUFFIXES:
        _stem = Path(_stem).stem
    _name = _stem
    if _name in _SAMPLE_TO_GENOME:
        raise ValueError(
            f"Duplicate sample name '{_name}' derived from '{_p}' and "
            f"'{_SAMPLE_TO_GENOME[_name]}'. Rename one of the genome files."
        )
    _SAMPLE_TO_GENOME[_name] = _p


rule all:
    input:
        expand(
            "results/final/{sample}_{te_name}.done",
            sample=list(_SAMPLE_TO_GENOME),
            te_name=config["te_name"],
        ),


rule build_database:
    """
    Build a database from the input genome assembly
    """
    input:
        genome=lambda wildcards: _SAMPLE_TO_GENOME[wildcards.sample],
    output:
        multiext(
            "results/rmod_database/{sample}/{sample}_rmod",
            ".nhr",
            ".nin",
            ".njs",
            ".nnd",
            ".nni",
            ".nog",
            ".nsq",
        ),
        translation="results/rmod_database/{sample}/{sample}_rmod.translation",
    log:
        "results/logs/{sample}_build_database.log",
    conda:
        "envs/repeatmodeler.yaml"
    params:
        basename=lambda wildcards: f"results/rmod_database/{wildcards.sample}/{wildcards.sample}_rmod",
    shell:
        """(BuildDatabase -name {params.basename} {input.genome}) > {log} 2>&1"""


rule repeatmodeler:
    """
    Run RepeatModeler2 using the database files from the previous rule
    """
    input:
        nhr="results/rmod_database/{sample}/{sample}_rmod.nhr",
    output:
        families="results/rmod_families/{sample}/{sample}_rmod-families.fa",
    log:
        "results/logs/{sample}_run_repeatmodeler2.log",
    threads: 8
    conda:
        "envs/repeatmodeler.yaml"
    params:
        db_basename=lambda wildcards, input: input.nhr.replace(".nhr", ""),
    script:
        "scripts/run_repeatmodeler.py"


rule collect_te:
    input:
        families="results/rmod_families/{sample}/{sample}_rmod-families.fa",
    output:
        collection="results/collect_te/{sample}/{sample}_{te_name}_family.fa",
    log:
        "results/logs/{sample}_{te_name}_collect_te.log",
    params:
        te_name=lambda wildcards: wildcards.te_name,
    conda:
        "envs/biopython.yaml"
    script:
        "scripts/collect_te.py"


rule repeatmasker:
    input:
        fasta=lambda wildcards: _SAMPLE_TO_GENOME[wildcards.sample],
        te_lib="results/collect_te/{sample}/{sample}_{te_name}_family.fa",
    output:
        repeatmasker_dir=directory("results/repeatmasker/{sample}_{te_name}"),
    log:
        "results/logs/{sample}_{te_name}_repeatmasker.log",
    params:
        engine=config.get("repeatmasker", {}).get("engine", "rmblast"),
        extra=config.get("repeatmasker", {}).get("extra", ""),
    threads: 8
    conda:
        "envs/repeatmasker.yaml"
    shell:
        """
        RepeatMasker \
            -pa {threads} \
            -lib {input.te_lib} \
            -dir {output.repeatmasker_dir} \
            -gff \
            -engine {params.engine} \
            {params.extra} \
            {input.fasta} > {log} 2>&1
        """


