PssmWithParameters ::= {
  pssm {
    isProtein TRUE,
    numRows 28,
    numColumns 189,
    byRow FALSE,
    query seq {
      id {
        general {
          db "CDD",
          tag id 278506
        }
      },
      descr {
        title "pfam00078, RVT_1, Reverse transcriptase (RNA-dependent DNA
 polymerase).  A reverse transcriptase gene is usually indicative of a mobile
 element such as a retrotransposon or retrovirus. Reverse transcriptases occur
 in a variety of mobile elements, including retrotransposons, retroviruses,
 group II introns, bacterial msDNAs, hepadnaviruses, and caulimoviruses."
      },
