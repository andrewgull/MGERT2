PssmWithParameters ::= {
  pssm {
    isProtein TRUE,
    numRows 28,
    numColumns 246,
    byRow FALSE,
    query seq {
      id {
        general {
          db "CDD",
          tag id 285028
        }
      },
      descr {
        title "pfam07727, RVT_2, Reverse transcriptase (RNA-dependent DNA
 polymerase).  A reverse transcriptase gene is usually indicative of a mobile
 element such as a retrotransposon or retrovirus. Reverse transcriptases occur
 in a variety of mobile elements, including retrotransposons, retroviruses,
 group II introns, bacterial msDNAs, hepadnaviruses, and caulimoviruses. This
 Pfam entry includes reverse transcriptases not recognized by the pfam00078
 model."
      },
      inst {
        repr raw,
        mol aa,
